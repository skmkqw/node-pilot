{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "NodePilot": "Debug",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore": "Warning"
        }
    },
    "Monitoring": {
        "Collection": {
            "Enabled": true,
            "IntervalSeconds": 15,
            "CollectCpuUsage": true,
            "CollectRamUsage": true,
            "CollectDiskUsage": false,
            "CollectTemperature": false
        },
        "Retention": {
            "CleanupEnabled": true,
            "MaxMetricAgeHours": 72,
            "CleanupIntervalMinutes": 30,
            "MaxStoredSamples": 250000
        },
        "Alerts": {
            "NotificationsEnabled": false,
            "CpuWarningThresholdPercent": 85,
            "RamWarningThresholdPercent": 90,
            "DiskWarningThresholdPercent": 90,
            "CpuTemperatureWarningCelsius": 80
        }
    },
    "AllowedHosts": "*"
}