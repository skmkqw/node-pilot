{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "NodePilot": "Debug",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore": "Warning"
        }
    },
    "Monitoring": {
        "Collection": {
            "Enabled": true,
            "CollectCpuUsage": true,
            "CollectRamUsage": true,
            "CollectDiskUsage": false,
            "CollectTemperature": false
        },
        "Retention": {
            "CleanupEnabled": true,
            "MaxMetricAgeHours": 6,
            "CleanupIntervalMinutes": 5,
            "MaxStoredSamples": 50000
        },
        "Alerts": {
            "NotificationsEnabled": false,
            "CpuWarningThresholdPercent": 70,
            "RamWarningThresholdPercent": 75,
            "DiskWarningThresholdPercent": 85,
            "CpuTemperatureWarningCelsius": 70
        }
    }
}