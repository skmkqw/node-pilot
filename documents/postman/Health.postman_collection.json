{
	"info": {
		"_postman_id": "787469de-45aa-4919-b8e6-fae2b8983ccb",
		"name": "Health",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "34323364"
	},
	"item": [
		{
			"name": "CheckHealth",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response is JSON\", function () {",
							"    pm.response.to.be.json;",
							"});",
							"",
							"const json = pm.response.json();",
							"",
							"pm.test(\"Top-level health fields exist\", function () {",
							"    pm.expect(json).to.have.property(\"status\");",
							"    pm.expect(json).to.have.property(\"totalDuration\");",
							"    pm.expect(json).to.have.property(\"checks\");",
							"});",
							"",
							"pm.test(\"Application health is Healthy\", function () {",
							"    pm.expect(json.status).to.eql(\"Healthy\");",
							"});",
							"",
							"pm.test(\"Checks array exists and is not empty\", function () {",
							"    pm.expect(json.checks).to.be.an(\"array\");",
							"    pm.expect(json.checks.length).to.be.above(0);",
							"});",
							"",
							"pm.test(\"system_status check exists\", function () {",
							"    const systemStatusCheck = json.checks.find(c => c.name === \"system_status\");",
							"    pm.expect(systemStatusCheck).to.exist;",
							"});",
							"",
							"pm.test(\"system_status check is Healthy\", function () {",
							"    const systemStatusCheck = json.checks.find(c => c.name === \"system_status\");",
							"    pm.expect(systemStatusCheck.status).to.eql(\"Healthy\");",
							"});",
							"",
							"pm.test(\"system_status contains runtime data\", function () {",
							"    const systemStatusCheck = json.checks.find(c => c.name === \"system_status\");",
							"",
							"    pm.expect(systemStatusCheck.data).to.have.property(\"dotnetVersion\");",
							"    pm.expect(systemStatusCheck.data).to.have.property(\"processors\");",
							"    pm.expect(systemStatusCheck.data).to.have.property(\"osVersion\");",
							"    pm.expect(systemStatusCheck.data).to.have.property(\"os\");",
							"",
							"    pm.expect(systemStatusCheck.data.processors).to.be.a(\"number\");",
							"    pm.expect(systemStatusCheck.data.processors).to.be.above(0);",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/health",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"health"
					]
				}
			},
			"response": []
		}
	]
}